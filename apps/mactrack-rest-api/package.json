{
    "type": "module",
    "name": "@mactrack/rest-api",
    "version": "1.0.0",
    "description": "This project was bootstrapped with Fastify-CLI.",
    "main": "app.ts",
    "directories": {
        "test": "test"
    },
    "scripts": {
        "test": "pnpm run build:ts && tsc -p test/tsconfig.json && FASTIFY_AUTOLOAD_TYPESCRIPT=1 node --test --experimental-test-coverage --loader ts-node/esm test/**/*.ts",
        "start": "fastify start -l info dist/app.js",
        "build:ts": "tsc",
	"build:ts": "pnpm run build:ts",
        "watch:ts": "tsc -w",
        "dev": "pnpm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch:ts\" \"pnpm:dev:start\"",
        "dev:start": "fastify start --options --ignore-watch=.ts$ -w -l info -P dist/app.js",
        "update-db-types": " pnpm dlx supabase gen types typescript --project-id \"mjmmgqaihrvaiijaoaoq\" --schema public > src/types/database.types.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@fastify/autoload": "^6.0.0",
        "@fastify/sensible": "^6.0.0",
        "date-fns": "^4.1.0",
        "date-fns-tz": "^3.2.0",
        "dotenv": "^17.4.2",
        "@mactrack/utils": "workspace:*",
        "fastify": "^5.0.0",
        "fastify-cli": "^7.4.1",
        "fastify-plugin": "^5.0.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.8",
        "c8": "^10.1.2",
        "concurrently": "^9.0.0",
        "fastify-tsconfig": "^3.0.0",
        "prettier": "3.8.1",
        "ts-node": "^10.4.0",
        "typescript": "~5.9.2"
    }
}
